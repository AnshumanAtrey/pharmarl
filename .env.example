# Copy to .env and fill in. .env is gitignored — never commit secrets.

# Hugging Face / deployment
# Required for deploying to HF Spaces and pushing trained adapters to the Hub.
# Get a write-scoped token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_write_scoped_token_here
HF_USERNAME=your-hf-username
HF_SPACE_NAME=pharmarl

# Training / Kaggle
# Set PHARMARL_ENV_URL to your deployed Space URL when training from Kaggle.
# Use /kaggle/working/... paths in notebook/script args for outputs/checkpoints.
PHARMARL_ENV_URL=https://your-hf-username-pharmarl.hf.space

# Optional tracking (Weights & Biases)
# WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=pharmarl
WANDB_RUN_NAME=kaggle-grpo-run

# Required only if you'll run inference.py (uses the OpenAI client). Costs money.
# OPENAI_API_KEY=sk-...

# Required only if you'll run examples/gemini_episode.py.
# Get a free or paid key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza...

# Required only if you'll run examples/openrouter_episode.py (Llama, Mistral, etc.).
# Sign up at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...

# Optional — opt into Stage 2 docking (requires pyscreener + Vina + OpenBabel).
# PHARMARL_ENABLE_DOCKING=1
