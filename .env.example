# Copy to .env and fill in. .env is gitignored — never commit secrets.

# Required for deploying to HF Spaces and pushing the trained model to the Hub.
# Get a token at https://huggingface.co/settings/tokens (write scope).
HF_TOKEN=hf_your_write_scoped_token_here
HF_USERNAME=your-hf-username
HF_SPACE_NAME=pharmarl

# Required only if you'll run inference.py (uses the OpenAI client). Costs money.
# OPENAI_API_KEY=sk-...

# Optional — point env-driven scripts at a specific server URL.
# PHARMARL_ENV_URL=http://localhost:8000

# Optional — opt into Stage 2 docking (requires pyscreener + Vina + OpenBabel).
# PHARMARL_ENABLE_DOCKING=1
